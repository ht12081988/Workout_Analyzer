{
  "expo": {
    "name": "VisionFit",
    "slug": "visionfit-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "VisionFit needs access to your camera to analyze your workout form."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.CAMERA"
      ],
      "package": "com.hardikt26.visionfitapp"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "react-native-vision-camera",
        {
          "cameraPermissionText": "VisionFit needs access to your camera to analyze your workout form."
        }
      ],
      "./plugins/withMediaPipe"
    ],
    "extra": {
      "eas": {
        "projectId": "436c395c-b507-4a4f-811e-077df968f04c"
      }
    }
  }
}
